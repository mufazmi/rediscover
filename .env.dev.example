# Development Environment Variables for Rediscover Application
# Copy this file to .env for development with reverse proxy testing

# =============================================================================
# APPLICATION SECURITY (Development Values)
# =============================================================================

# Secret key for JWT tokens and session encryption
# Development value - change for production
APP_SECRET=dev-secret-key-change-in-production

# JWT token expiration time
# Longer expiration for development convenience
JWT_EXPIRES_IN=7d

# =============================================================================
# DEVELOPMENT REVERSE PROXY CONFIGURATION
# =============================================================================

# Frontend URL for CORS configuration
# For development with nginx reverse proxy on port 8080
FRONTEND_URL=http://localhost:8080

# Frontend API URL (for build-time configuration)
# Options for development:
#   "" (empty) - Use relative URLs through nginx reverse proxy
#   "http://localhost:6377" - Direct backend access (bypass proxy)
VITE_API_URL=

# =============================================================================
# DATABASE CONFIGURATION
# =============================================================================

# Path to SQLite database file (local development)
DATABASE_PATH=./data/rediscover.db

# Data directory for application files
DATA_DIR=./data

# =============================================================================
# SERVER CONFIGURATION
# =============================================================================

# Port for the backend server
PORT=6377

# Node.js environment
NODE_ENV=development

# =============================================================================
# SECURITY CONFIGURATION
# =============================================================================

# Number of bcrypt rounds for password hashing
# Lower value for faster development
BCRYPT_ROUNDS=10

# JWT expiration time (alternative to JWT_EXPIRES_IN)
JWT_EXPIRATION=7d

# =============================================================================
# DOCKER CONFIGURATION
# =============================================================================

# Nginx port configuration for development
# HTTP port for nginx reverse proxy (different from production to avoid conflicts)
NGINX_DEV_PORT=8080

# Frontend development server port
FRONTEND_DEV_PORT=6378

# Backend development server port  
BACKEND_DEV_PORT=6377

# Application version
VITE_APP_VERSION=0.0.0-dev

# Build timestamp
BUILD_DATE=

# Git commit hash
GIT_COMMIT=

# =============================================================================
# DEVELOPMENT NOTES
# =============================================================================

# Development Setup Options:
# 
# 1. Reverse Proxy Development (Recommended for testing production setup):
#    - Use docker-compose -f docker-compose.prod.yml -f docker-compose.dev.yml up
#    - Access app at http://localhost:8080 (through nginx)
#    - Set VITE_API_URL="" for relative URLs
#    - Set FRONTEND_URL=http://localhost:8080
#
# 2. Direct Development (Faster for development):
#    - Run backend: cd backend && npm run dev
#    - Run frontend: npm run dev
#    - Access app at http://localhost:6378 (direct)
#    - Set VITE_API_URL="http://localhost:6377"
#    - Set FRONTEND_URL=http://localhost:6378
#
# 3. Hybrid Development:
#    - Use nginx for static files, direct backend access
#    - Set VITE_API_URL="http://localhost:6377"
#    - Access through nginx at http://localhost:8080