# Production Environment Variables for Rediscover Application
# Copy this file to .env for production deployment

# =============================================================================
# APPLICATION SECURITY (REQUIRED FOR PRODUCTION)
# =============================================================================

# Secret key for JWT tokens and session encryption
# CRITICAL: Generate a secure random string for production (64+ characters)
# You can use: openssl rand -base64 64
APP_SECRET=CHANGE-THIS-TO-A-SECURE-RANDOM-STRING-IN-PRODUCTION

# JWT token expiration time
# Shorter expiration for production security
JWT_EXPIRES_IN=24h

# =============================================================================
# PRODUCTION DEPLOYMENT CONFIGURATION
# =============================================================================

# Frontend URL for CORS configuration
# Set this to your production domain
# Examples:
#   With custom domain: https://your-domain.com
#   With nginx reverse proxy: http://localhost (same origin)
FRONTEND_URL=https://your-domain.com

# Frontend API URL (for build-time configuration)
# Leave empty for relative URLs (recommended for reverse proxy deployment)
VITE_API_URL=

# =============================================================================
# DATABASE CONFIGURATION
# =============================================================================

# Path to SQLite database file (Docker container path)
DATABASE_PATH=/app/data/rediscover.db

# =============================================================================
# SERVER CONFIGURATION
# =============================================================================

# Port for the backend server (internal Docker network)
PORT=6377

# Node.js environment
NODE_ENV=production

# =============================================================================
# SECURITY CONFIGURATION
# =============================================================================

# Number of bcrypt rounds for password hashing
# Higher values for production security (12 recommended)
BCRYPT_ROUNDS=12

# =============================================================================
# DOCKER CONFIGURATION
# =============================================================================

# Nginx port configuration
# HTTP port for nginx reverse proxy
NGINX_HTTP_PORT=80

# HTTPS port for nginx reverse proxy (when SSL is enabled)
NGINX_HTTPS_PORT=443

# =============================================================================
# BUILD CONFIGURATION
# =============================================================================

# Application version (set by CI/CD)
VITE_APP_VERSION=1.0.0

# Build timestamp (set by CI/CD)
BUILD_DATE=

# Git commit hash (set by CI/CD)
GIT_COMMIT=

# =============================================================================
# PRODUCTION DEPLOYMENT NOTES
# =============================================================================

# Production Deployment Steps:
# 
# 1. Copy this file to .env and update all values
# 2. Generate a secure APP_SECRET: openssl rand -base64 64
# 3. Set FRONTEND_URL to your production domain
# 4. Leave VITE_API_URL empty for relative URLs
# 5. Configure SSL certificates in nginx/ssl/ directory
# 6. Run: docker-compose -f docker-compose.prod.yml up -d
#
# Security Checklist:
# - [ ] APP_SECRET is a secure random string (64+ characters)
# - [ ] FRONTEND_URL matches your production domain
# - [ ] BCRYPT_ROUNDS is set to 12 or higher
# - [ ] SSL certificates are properly configured
# - [ ] Database backups are configured
# - [ ] Log monitoring is set up