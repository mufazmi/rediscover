{
  "name": "rediscover-backend",
  "version": "1.0.1",
  "description": "Self-hosted Node.js + Express backend for Rediscover",
  "main": "dist/server.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [
    "redis",
    "backend",
    "express"
  ],
  "author": "Umair Farooqui <info.umairfarooqui@gmail.com> (https://umairfarooqui.com)",
  "license": "MIT",
  "dependencies": {
    "bcrypt": "^5.1.0",
    "better-sqlite3": "^9.4.0",
    "cors": "^2.8.5",
    "dotenv": "^16.3.0",
    "express": "^4.18.0",
    "express-rate-limit": "^7.1.0",
    "helmet": "^7.1.0",
    "ioredis": "^5.3.0",
    "jsonwebtoken": "^9.0.0",
    "node-fetch": "^3.3.0",
    "socket.io": "^4.7.0",
    "uuid": "^9.0.0",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.0",
    "@types/better-sqlite3": "^7.6.0",
    "@types/cors": "^2.8.0",
    "@types/express": "^4.17.0",
    "@types/jsonwebtoken": "^9.0.0",
    "@types/node": "^20.0.0",
    "@types/supertest": "^7.2.0",
    "@types/uuid": "^9.0.0",
    "fast-check": "^4.6.0",
    "supertest": "^7.2.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.3.0",
    "vitest": "^4.1.0"
  }
