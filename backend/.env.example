# Backend Environment Variables for Rediscover Application
# This file is for backend-only development
# For full application deployment, use the .env files in the project root

# =============================================================================
# SERVER CONFIGURATION
# =============================================================================

# Port for the backend server
PORT=6377

# Node.js environment
NODE_ENV=development

# =============================================================================
# SECURITY CONFIGURATION
# =============================================================================

# Secret key for JWT tokens and session encryption
# Generate secure value for production: openssl rand -base64 64
APP_SECRET=dev-secret-key-change-in-production

# JWT expiration time
JWT_EXPIRATION=7d

# Number of bcrypt rounds for password hashing
BCRYPT_ROUNDS=10

# =============================================================================
# DATABASE CONFIGURATION
# =============================================================================

# Path to SQLite database file
# Use relative path for backend-only development
DATABASE_PATH=data/rediscover.db

# =============================================================================
# CORS CONFIGURATION
# =============================================================================

# Frontend URL for CORS configuration
# Set to match where your frontend is running
# Examples:
#   Direct frontend dev server: http://localhost:6378
#   Nginx reverse proxy: http://localhost:8080
#   Production domain: https://your-domain.com
FRONTEND_URL=http://localhost:6378

# =============================================================================
# NOTES
# =============================================================================

# This file is for backend-only development.
# For full application deployment with reverse proxy, use:
# - .env.example (development)
# - .env.prod.example (production)
# - .env.dev.example (development with reverse proxy)
# 
# These files are located in the project root directory.