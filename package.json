{
  "name": "@mufazmi/rediscover",
  "private": false,
  "version": "1.0.0",
  "type": "module",
  "description": "Self-hosted Redis management tool with a beautiful web interface",
  "bin": {
    "rediscover": "./bin/rediscover.cjs"
  },
  "files": [
    "dist/",
    "backend/dist/",
    "backend/package.json",
    "backend/node_modules/",
    "bin/"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "keywords": [
    "redis",
    "management",
    "gui",
    "self-hosted",
    "database",
    "admin",
    "monitoring"
  ],
  "homepage": "https://github.com/mufazmi/rediscover#readme",
  "bugs": {
    "url": "https://github.com/mufazmi/rediscover/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/mufazmi/rediscover.git"
  },
  "author": "Umair Farooqui <info.umairfarooqui@gmail.com> (https://umairfarooqui.com)",
  "license": "MIT",
  "preferGlobal": true,
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:dev": "vite build --mode development",
    "lint": "eslint .",
    "preview": "vite preview",
    "prepare": "cd backend && npm install --ignore-scripts && npm rebuild better-sqlite3",
    "version": "node scripts/sync-version.cjs && git add backend/package.json .env.production README.md CHANGELOG.md"
  },
  "dependencies": {
    "@hookform/resolvers": "^3.10.0",
    "@radix-ui/react-accordion": "^1.2.11",
    "@radix-ui/react-alert-dialog": "^1.1.14",
